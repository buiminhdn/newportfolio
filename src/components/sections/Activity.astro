---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import SectionTitle from "../SectionTitle.astro";

/**
 * Activity — vertical ledger, each row with a 3-image grid below.
 * Images: src/assets/activity/<key>-<n>.{jpg,png,webp} (n = 1..3); missing → /placeholder.png.
 */
const activityImgs = import.meta.glob<{ default: ImageMetadata }>(
  "../../assets/activity/*.{jpg,jpeg,png,webp,avif}",
  { eager: true },
);
const imgsByKey: Record<string, ImageMetadata[]> = {};
for (const [path, mod] of Object.entries(activityImgs)) {
  const base = path
    .split("/")
    .pop()!
    .replace(/\.[^.]+$/, ""); // "volleyball-1"
  const key = base.replace(/-\d+$/, ""); // "volleyball"
  (imgsByKey[key] ??= []).push(mod.default);
}
const pick3 = (key: string): (ImageMetadata | undefined)[] => {
  const imgs = imgsByKey[key] ?? [];
  return Array.from({ length: 3 }, (_, i) => imgs[i]);
};

const activities = [
  {
    key: "volleyball",
    role: "Volleyball",
    org: "Team Sports",
    period: "Favorite",
    points: [
      "Develops teamwork, communication and competitive spirit.",
      "A regular activity that helps maintain discipline and consistency.",
    ],
  },
  {
    key: "fitness",
    role: "Running & Swimming",
    org: "Fitness & Endurance",
    period: "Weekly",
    points: [
      "Improves physical fitness, focus and mental clarity.",
      "Provides balance between work, learning and personal well-being.",
    ],
  },
  {
    key: "recreation",
    role: "Basketball & Badminton",
    org: "Recreation & Social Activities",
    period: "Regular",
    points: [
      "Enjoy fast-paced sports that combine strategy, movement and coordination.",
      "A great way to stay active and connect with friends and communities.",
    ],
  },
];
---

<section class="section container" id="experience" aria-labelledby="exp-title">
  <SectionTitle id="exp-title" eyebrow="always shipping">Activity</SectionTitle>

  <ol class="ledger">
    {
      activities.map((j, i) => (
        <li class="row">
          <div class="meta">
            <span class="idx">{String(i + 1).padStart(2, "0")}</span>
            <span class="period">{j.period}</span>
          </div>
          <div class="detail">
            <h3 class="role">{j.role}</h3>
            <p class="org text-accent">{j.org}</p>
            <ul class="points">
              {j.points.map((p) => (
                <li class="text-muted fw-extralight">{p}</li>
              ))}
            </ul>
            <div class="gallery">
              {pick3(j.key).map((img, n) =>
                img ? (
                  <figure class="shot">
                    <Image
                      src={img}
                      alt={`${j.role} photo ${n + 1}`}
                      width={420}
                      height={315}
                      format="webp"
                      loading="lazy"
                    />
                  </figure>
                ) : (
                  <figure class="shot">
                    <img
                      src="/placeholder.png"
                      alt=""
                      width={420}
                      height={315}
                      loading="lazy"
                    />
                    <figcaption class="ph-note">
                      {j.key}-{n + 1}.jpg
                    </figcaption>
                  </figure>
                ),
              )}
            </div>
          </div>
        </li>
      ))
    }
  </ol>
</section>

<style>
  .ledger {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    padding-block: var(--space-8);
    border-top: 1px solid var(--color-border-line);
  }
  .row:last-child {
    border-bottom: 1px solid var(--color-border-line);
  }
  .meta {
    display: flex;
    align-items: baseline;
    gap: var(--space-4);
  }
  .idx {
    font-size: var(--fs-h3);
    line-height: 1;
    color: var(--color-primary);
    font-variant-numeric: tabular-nums;
  }
  .period {
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-text-muted);
  }
  .role {
    margin: 0;
    font-size: var(--fs-h2);
    font-weight: var(--fw-medium);
    line-height: 1.15;
  }
  .org {
    margin: var(--space-1) 0 var(--space-5);
    font-size: var(--fs-sm);
  }
  .points {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: var(--space-2);
    max-width: 48rem;
  }
  .points li {
    position: relative;
    padding-left: var(--space-5);
    font-size: var(--fs-sm);
  }
  .points li::before {
    content: "▹";
    position: absolute;
    left: 0;
    color: var(--color-accent);
  }

  .gallery {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-2);
    margin-top: var(--space-5);
    max-width: 24rem;
  }
  .shot {
    position: relative;
    margin: 0;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border-soft);
    background: var(--color-surface);
  }
  .shot :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .ph-note {
    position: absolute;
    left: var(--space-1);
    bottom: var(--space-1);
    margin: 0;
    font-family: var(--font);
    font-size: 0.625rem;
    color: var(--color-text);
    background: rgba(8, 8, 11, 0.7);
    border-radius: var(--radius-full);
    padding: 0 var(--space-2);
  }

  @media (min-width: 768px) {
    .row {
      grid-template-columns: 15rem 1fr;
      gap: var(--space-10);
    }
    .meta {
      flex-direction: column;
      gap: var(--space-2);
    }
  }
</style>
