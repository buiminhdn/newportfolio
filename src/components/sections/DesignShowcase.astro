---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import SectionTitle from '../SectionTitle.astro';
import { brands } from '../../data/designShowcase';

/**
 * Brand & Creative Work — 4 images per brand, no text, no rounded corners.
 * Tabs switch the brand → swaps the image set. Left big image; right = 2 top + 1 wide.
 * Images: src/assets/design/<slug>-1..4.{jpg,png,webp}; missing → /placeholder.png.
 */
export interface Props {
	id?: string;
}
const { id = 'design' } = Astro.props;

const designImages = import.meta.glob<{ default: ImageMetadata }>(
	'../../assets/design/*.{jpg,jpeg,png,webp,avif}',
	{ eager: true },
);
const pick = (slug: string, n: number): ImageMetadata | undefined => {
	const match = Object.entries(designImages).find(([path]) =>
		path.split('/').pop()?.startsWith(`${slug}-${n}.`),
	);
	return match?.[1].default;
};
---

<section class="section container" id={id} aria-labelledby={`${id}-title`} data-design-tabs>
	<div class="head">
		<SectionTitle id={`${id}-title`} eyebrow="creative direction · studio work">Brand &amp; Creative Work</SectionTitle>
		<p class="subtitle text-muted">Where brand meets emotion — visual identities built to stand out.</p>
	</div>

	<div class="tabs" role="tablist" aria-label="Brands">
		{
			brands.map((b, i) => (
				<button class="tab" type="button" role="tab" data-tab={b.slug} aria-selected={i === 0 ? 'true' : 'false'}>
					{b.name}
				</button>
			))
		}
	</div>

	<div class="panels">
		{
			brands.map((b, bi) => {
				const imgs = [1, 2, 3, 4].map((n) => pick(b.slug, n));
				return (
					<div class="panel" data-panel={b.slug} hidden={bi !== 0}>
						<div class="bento">
							<div class="dcard big">
								{imgs[0] ? (
									<Image src={imgs[0]} alt={`${b.name} — 1`} width={900} height={1100} format="webp" loading="lazy" />
								) : (
									<img src="/placeholder.png" alt="" width={900} height={1100} loading="lazy" />
								)}
							</div>
							<div class="right">
								{[imgs[1], imgs[2], imgs[3]].map((im, i) => (
									<div class={`dcard${i === 2 ? ' wide' : ''}`}>
										{im ? (
											<Image src={im} alt={`${b.name} — ${i + 2}`} width={900} height={700} format="webp" loading="lazy" />
										) : (
											<img src="/placeholder.png" alt="" width={900} height={700} loading="lazy" />
										)}
									</div>
								))}
							</div>
						</div>
					</div>
				);
			})
		}
	</div>
</section>

<style>
	.head :global(.section-title) {
		margin-bottom: var(--space-3);
	}
	.subtitle {
		margin: 0 0 var(--space-8);
		max-width: 32rem;
		font-size: var(--fs-lg);
		font-weight: var(--fw-light);
	}

	/* ── Tabs ── */
	.tabs {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-3);
		margin-bottom: var(--space-8);
	}
	.tab {
		font: inherit;
		font-size: var(--fs-sm);
		padding: var(--space-2) var(--space-5);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-full);
		background: transparent;
		color: var(--color-text-muted);
		cursor: pointer;
	}
	.tab[aria-selected='true'] {
		border-color: var(--color-primary);
		background: var(--color-primary);
		color: var(--color-on-primary);
	}

	/* ── Image grid ── */
	.panel[hidden] {
		display: none;
	}
	.bento {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-3);
	}
	.right {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: var(--space-3);
	}
	.right .wide {
		grid-column: span 2;
	}
	.dcard {
		position: relative;
		overflow: hidden;
		background: var(--color-secondary);
		aspect-ratio: 4 / 3;
	}
	.dcard.big {
		aspect-ratio: 4 / 5;
	}
	.dcard.wide {
		aspect-ratio: 16 / 9;
	}
	.dcard :is(img) {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		max-width: none;
		object-fit: cover;
		display: block;
	}

	/* desktop: 2 cột — trái lớn full chiều cao; phải 2 hàng (trên 2 ảnh, dưới 1 ảnh) */
	@media (min-width: 768px) {
		.bento {
			grid-template-columns: 1fr 1fr;
			height: 32rem;
		}
		.right {
			grid-template-rows: 1fr 1fr;
		}
		.dcard,
		.dcard.big,
		.dcard.wide {
			aspect-ratio: auto;
			height: 100%;
		}
	}
</style>

<script>
	for (const root of document.querySelectorAll<HTMLElement>('[data-design-tabs]')) {
		const tabs = root.querySelectorAll<HTMLButtonElement>('[data-tab]');
		const panels = root.querySelectorAll<HTMLElement>('[data-panel]');
		for (const tab of tabs) {
			tab.addEventListener('click', () => {
				const slug = tab.dataset.tab;
				for (const t of tabs) t.setAttribute('aria-selected', String(t === tab));
				for (const p of panels) p.hidden = p.dataset.panel !== slug;
			});
		}
	}
</script>
