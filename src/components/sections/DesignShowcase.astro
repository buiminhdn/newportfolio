---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import SectionTitle from '../SectionTitle.astro';
import { designShowcase } from '../../data/designShowcase';

/**
 * Creative Design Showcase — asymmetrical Bento Grid (dark luxury).
 * Không hover effect. Text (category + title) luôn nằm trên ảnh, có gradient để đọc.
 * Kích thước ô do col/row trong data. Ảnh cover lấp đầy ô.
 * Ảnh thật: src/assets/design/<slug>.{jpg,png,webp}; chưa có → /placeholder.png.
 */
export interface Props {
	id?: string;
}
const { id = 'design' } = Astro.props;

const designImages = import.meta.glob<{ default: ImageMetadata }>(
	'../../assets/design/*.{jpg,jpeg,png,webp,avif}',
	{ eager: true },
);
const imageFor = (slug: string): ImageMetadata | undefined => {
	const match = Object.entries(designImages).find(([path]) =>
		path.split('/').pop()?.startsWith(`${slug}.`),
	);
	return match?.[1].default;
};
---

<section class="section container grid-bg" id={id} aria-labelledby={`${id}-title`}>
	<SectionTitle id={`${id}-title`} eyebrow="creative direction · studio work">Design Showcase</SectionTitle>

	<div class="bento">
		{
			designShowcase.map((p) => {
				const img = imageFor(p.slug);
				return (
					<article class="dcard reveal" style={`--accent:${p.accent}; --col:${p.col};`}>
						{img ? (
							<Image src={img} alt={`${p.title} — ${p.category}`} width={1000} height={1000} format="webp" loading="lazy" />
						) : (
							<img src="/placeholder.png" alt="" width={1000} height={1000} loading="lazy" />
						)}

						<div class="overlay">
							<span class="cat">{p.category}</span>
							<h3 class="title">{p.title}</h3>
						</div>
					</article>
				);
			})
		}
	</div>
</section>

<style>
	/* ── Asymmetrical Bento Grid — đúng 2 hàng × 4 cột (desktop) ── */
	.bento {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		grid-auto-rows: 13rem;
		grid-auto-flow: dense;
		gap: var(--space-4);
	}
	@media (min-width: 768px) {
		.bento {
			grid-template-columns: repeat(4, 1fr);
			grid-template-rows: repeat(2, 1fr);
			grid-auto-rows: 1fr;
			height: 34rem;
			gap: var(--space-5);
		}
	}

	/* ── Card ── */
	.dcard {
		position: relative;
		overflow: hidden;
		border-radius: var(--radius-lg);
		border: 1px solid var(--color-border-line);
		background: var(--color-surface);
		grid-column: span var(--col);
		grid-row: span var(--row);
	}
	/* mobile: ô 2 cột = full width; giữ row span để vẫn bất đối xứng */

	.dcard :is(img) {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		max-width: none;
		object-fit: cover;
		display: block;
	}

	/* gradient + text — luôn hiển thị */
	.overlay {
		position: absolute;
		inset: 0;
		z-index: 1;
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
		gap: var(--space-2);
		padding: var(--space-5);
		background: linear-gradient(
			to top,
			rgba(8, 8, 11, 0.9) 0%,
			rgba(8, 8, 11, 0.45) 38%,
			rgba(8, 8, 11, 0) 70%
		);
	}
	.cat {
		align-self: flex-start;
		font-family: var(--font-mono);
		font-size: var(--fs-xs);
		text-transform: uppercase;
		letter-spacing: 0.16em;
		padding: var(--space-1) var(--space-3);
		border-radius: var(--radius-full);
		color: var(--color-on-primary);
		background: var(--accent);
	}
	.title {
		margin: 0;
		font-family: var(--font-display);
		font-size: var(--fs-h3);
		letter-spacing: 0.02em;
		line-height: var(--lh-tight);
		color: var(--color-text);
		text-shadow: 0 2px 18px rgba(0, 0, 0, 0.7);
	}
</style>
