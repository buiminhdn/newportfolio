---
import type { ImageMetadata } from 'astro';
import SectionTitle from '../SectionTitle.astro';
import ProjectCard from '../ProjectCard.astro';

/**
 * Project Gallery — chỉ giữ 4–6 dự án tốt nhất (không liệt kê tất cả).
 * Ảnh: src/assets/projects/<slug>.{jpg,png,webp}; chưa có → /placeholder.png.
 * `metric` = slot impact (TODO số liệu thật).
 */
const projectImages = import.meta.glob<{ default: ImageMetadata }>(
	'../../assets/projects/*.{jpg,jpeg,png,webp,avif}',
	{ eager: true },
);
const imageFor = (slug: string): ImageMetadata | undefined => {
	const match = Object.entries(projectImages).find(([path]) =>
		path.split('/').pop()?.startsWith(`${slug}.`),
	);
	return match?.[1].default;
};

const projects = [
	{
		slug: 'hango',
		name: 'Hango',
		category: 'Best Product',
		description: 'Interest-based platform to find groups, join events and chat in real time.',
		tech: ['Next.js', 'Supabase', 'WebSocket'],
		metric: 'TODO: impact metric',
	},
	{
		slug: 'seenic',
		name: 'Seenic',
		category: 'Best Mobile-first',
		description: 'Local discovery platform with auth, image upload, filtering and pagination.',
		tech: ['Next.js', 'TypeScript', 'Firebase'],
		metric: 'TODO: impact metric',
	},
	{
		slug: 'emotion-wallpaper',
		name: 'Emotion Wallpaper',
		category: 'Best Android App',
		description: 'Change your wallpaper based on your current mood — fast and personalized.',
		tech: ['Kotlin', 'Jetpack Compose'],
		metric: 'TODO: installs / rating',
	},
	{
		slug: 'sams-english-school',
		name: "Sam's English School",
		category: 'Best Design',
		description: 'Education website optimized for mobile and SEO to support enrollment.',
		tech: ['React', 'Tailwind CSS'],
		links: [{ label: 'Live', href: 'https://samenglishschool.com/' }],
	},
	{
		slug: 'android-tools',
		name: 'Android Tools',
		category: 'Best Dev Tool',
		description: 'Browser-based toolkit: JSON→Room, API Tester, Image→WebP and more.',
		tech: ['Web', 'Developer Tools'],
		links: [{ label: 'Live', href: 'https://android.buiminh.com/' }],
	},
	{
		slug: 'memory-calendar',
		name: 'Memory Calendar',
		category: 'Best Local-first',
		description: 'Save moments and memories as a calendar — local-first and privacy-friendly.',
		tech: ['Kotlin', 'Room'],
		metric: 'TODO: installs / rating',
	},
];
---

<section class="section container" id="projects" aria-labelledby="projects-title">
	<SectionTitle id="projects-title" eyebrow="selected work">Project Gallery</SectionTitle>

	<div class="gallery">
		{projects.map((p, i) => <ProjectCard {...p} image={imageFor(p.slug)} index={i} />)}
	</div>

	<p class="more reveal text-muted">
		More Android apps under <strong>Marcus Labs</strong> —
		<a href="https://marcus.buiminh.com/" class="link" target="_blank" rel="noopener"
			>marcus.buiminh.com ↗</a
		>
	</p>
</section>

<style>
	.gallery {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-8);
	}
	.more {
		margin-top: var(--space-16);
		text-align: center;
		font-family: var(--font-mono);
		font-size: var(--fs-sm);
	}
	@media (min-width: 640px) {
		.gallery {
			grid-template-columns: repeat(2, 1fr);
		}
	}
	@media (min-width: 1024px) {
		.gallery {
			grid-template-columns: repeat(3, 1fr);
		}
	}
</style>
