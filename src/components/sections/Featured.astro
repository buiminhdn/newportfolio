---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import SectionTitle from '../SectionTitle.astro';
import Chip from '../Chip.astro';

/**
 * Featured Project — case study chi tiết cho 1 dự án tốt nhất.
 * Ảnh: src/assets/featured.{jpg,png,webp}; chưa có → /placeholder.png.
 * Số liệu Results: TODO — thay bằng metric THẬT (không bịa).
 */
const featuredGlob = import.meta.glob<{ default: ImageMetadata }>(
	'../../assets/featured.{jpg,jpeg,png,webp,avif}',
	{ eager: true },
);
const shot = Object.values(featuredGlob)[0]?.default;

const project = {
	name: 'MYAmie',
	tagline: 'Cross-platform community system — web & mobile, realtime at its core.',
	tech: ['React', 'React Native', '.NET Core', 'PostgreSQL', 'Redis', 'SignalR', 'AWS', 'GitHub Actions'],
	problem:
		'A growing community needed a single place to connect across web and mobile — realtime conversations, reliable delivery, and an operations setup the small team could actually maintain.',
	solution:
		'A cross-platform system sharing one .NET Core backend across a React web app and a React Native mobile app, with realtime messaging over SignalR, Redis-backed fan-out, and an automated build/monitor pipeline.',
	challenges: [
		'Keeping realtime delivery consistent across web and mobile clients.',
		'Scaling message fan-out without overloading the database.',
		'Shipping safely with a small team — no room for manual, error-prone releases.',
	],
	decisions: [
		{ d: 'SignalR + Redis backplane', why: 'Reliable realtime fan-out that scales horizontally.' },
		{ d: 'Shared .NET Core API', why: 'One source of truth for web & mobile, less duplicated logic.' },
		{ d: 'CI/CD + monitoring (GitHub Actions, Grafana)', why: 'Safe, repeatable releases and early problem detection.' },
	],
	// TODO: thay bằng số liệu THẬT
	results: [
		{ value: '—', unit: '', label: 'Active Users' },
		{ value: '—', unit: '', label: 'Messages / day' },
		{ value: '—', unit: '', label: 'Uptime' },
		{ value: '—', unit: '', label: 'Crash-free rate' },
	],
};
---

<section class="section container grid-bg" id="featured" aria-labelledby="featured-title" data-parallax-root>
	<SectionTitle id="featured-title" eyebrow="featured case study">{project.name}</SectionTitle>

	<div class="lede grid-2">
		<div class="parallax" data-parallax="14">
			<div class="shot brutal tilt" data-tilt="6">
				{
					shot ? (
						<Image src={shot} alt={`${project.name} — screenshot`} width={1000} height={700} format="webp" loading="lazy" />
					) : (
						<img src="/placeholder.png" alt="" width={1000} height={700} loading="lazy" />
					)
				}
			</div>
		</div>

		<div class="reveal">
			<p class="tagline lead">{project.tagline}</p>
			<ul class="stack">
				{project.tech.map((t) => <Chip as="li">{t}</Chip>)}
			</ul>
		</div>
	</div>

	<div class="case">
		<article class="block reveal">
			<p class="eyebrow">problem</p>
			<p class="text-muted">{project.problem}</p>
		</article>

		<article class="block reveal">
			<p class="eyebrow">solution</p>
			<p class="text-muted">{project.solution}</p>
		</article>

		<article class="block reveal">
			<p class="eyebrow">challenges</p>
			<ul class="list">
				{project.challenges.map((c) => <li>{c}</li>)}
			</ul>
		</article>

		<article class="block reveal">
			<p class="eyebrow">key decisions</p>
			<ul class="decisions">
				{
					project.decisions.map((x) => (
						<li>
							<span class="d">{x.d}</span>
							<span class="why text-muted">{x.why}</span>
						</li>
					))
				}
			</ul>
		</article>
	</div>

	<div class="results reveal">
		<p class="eyebrow">results</p>
		{/* TODO: số liệu thật */}
		<dl class="results-grid">
			{
				project.results.map((r) => (
					<div class="metric">
						<dd class="value">
							{r.value}
							<span class="unit">{r.unit}</span>
						</dd>
						<dt class="label">{r.label}</dt>
					</div>
				))
			}
		</dl>
	</div>
</section>

<style>
	.lede {
		margin-bottom: var(--space-20);
	}
	.shot :is(img) {
		width: 100%;
		height: auto;
		display: block;
		border-radius: calc(var(--radius-md) - 2px);
	}
	.tagline {
		margin: 0 0 var(--space-6);
	}
	.stack {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2);
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.case {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-16);
	}
	.block .eyebrow {
		display: block;
		margin-bottom: var(--space-4);
	}
	.block p {
		margin: 0;
		max-width: 46rem;
	}
	.list,
	.decisions {
		margin: 0;
		padding: 0;
		list-style: none;
		display: grid;
		gap: var(--space-4);
		max-width: 46rem;
	}
	.list li {
		position: relative;
		padding-left: var(--space-6);
		color: var(--color-text-muted);
	}
	.list li::before {
		content: '';
		position: absolute;
		left: 0;
		top: 0.6em;
		width: 0.5rem;
		height: 0.5rem;
		border-radius: var(--radius-full);
		background: var(--color-accent);
	}
	.decisions li {
		display: grid;
		gap: var(--space-1);
		padding-left: var(--space-6);
		border-left: 2px solid var(--color-primary);
	}
	.decisions .d {
		font-weight: var(--fw-medium);
	}
	.decisions .why {
		font-size: var(--fs-sm);
	}

	.results {
		margin-top: var(--space-20);
	}
	.results > .eyebrow {
		display: block;
		margin-bottom: var(--space-6);
	}
	.results-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: var(--space-4);
		margin: 0;
	}
	.results-grid .value,
	.results-grid .label {
		margin: 0;
	}

	@media (min-width: 768px) {
		.case {
			grid-template-columns: 1fr 1fr;
			gap: var(--space-16) var(--space-20);
		}
		.results-grid {
			grid-template-columns: repeat(4, 1fr);
			gap: var(--space-6);
		}
	}
</style>
