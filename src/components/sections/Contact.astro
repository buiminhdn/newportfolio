---
/** Contact — closing CTA. TODO: add public/resume.pdf (link points there). */
const links = [
	{ label: 'Email', href: 'mailto:buiminhdn22@gmail.com' },
	{ label: 'GitHub', href: 'https://github.com/' }, // TODO: đúng username GitHub
	{ label: 'LinkedIn', href: 'https://www.linkedin.com/in/buiminhdn/' },
	{ label: 'Resume', href: '/resume.pdf' }, // TODO: thêm public/resume.pdf
];
---

<section class="section container" id="contact" aria-labelledby="contact-title">
	<div class="cta-wrap">
		<p class="eyebrow">get in touch</p>
		<h2 class="text-section headline">
			Let's build something <span class="text-accent">meaningful.</span>
		</h2>
		<p class="lead fw-extralight sub">
			Have a product or idea you want to ship? I'm open to interesting projects and
			full-time roles.
		</p>

		<div class="actions">
			<a href="mailto:buiminhdn22@gmail.com" class="btn-primary">CONTACT ME</a>
			<a href="tel:+84798851709" class="link">0798 851 709</a>
		</div>

		<ul class="quick">
			{
				links.map((l) => (
					<li>
						<a
							class="pill-contact"
							href={l.href}
							target={l.href.startsWith('http') ? '_blank' : undefined}
							rel={l.href.startsWith('http') ? 'noopener' : undefined}
						>
							{l.label}
						</a>
					</li>
				))
			}
		</ul>
	</div>
</section>

<style>
	.cta-wrap {
		text-align: center;
		max-width: 46rem;
		margin-inline: auto;
		padding-block: var(--space-16);
	}
	.cta-wrap .eyebrow {
		display: inline-block;
		margin-bottom: var(--space-5);
	}
	.headline {
		margin: 0;
	}
	.sub {
		margin: var(--space-6) auto 0;
		max-width: 32rem;
	}
	.actions {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: var(--space-6);
		margin-top: var(--space-10);
	}
	.quick {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: var(--space-3);
		list-style: none;
		margin: var(--space-10) 0 0;
		padding: 0;
	}
</style>
