---
import SectionTitle from '../SectionTitle.astro';

/** Experience — vertical timeline. Achievements with metrics are TODO. */
const jobs = [
	{
		role: 'Android Developer',
		org: 'Lutech Da Nang',
		period: '09/2025 — Present',
		points: [
			'Building production Android apps with Kotlin & Jetpack Compose.',
			'Clean architecture, testable code, smooth release workflow.',
			'TODO: achievement with real metric (e.g. users / crash-free rate).',
		],
	},
	{
		role: 'Freelance Developer & Designer',
		org: 'Self-employed',
		period: '01/2022 — Present',
		points: [
			'Designed & shipped websites, Android apps, UI/UX and Canva content.',
			'Worked directly with clients: requirements → design → build → maintain.',
			'TODO: achievement with real metric (e.g. projects delivered / clients).',
		],
	},
	{
		role: 'English Teacher',
		org: 'Education center',
		period: '09/2022 — 07/2023',
		points: [
			'Taught English and sharpened presentation & communication skills.',
			'Learned to explain complex ideas to diverse audiences.',
		],
	},
];
---

<section class="section container" id="experience" aria-labelledby="exp-title">
	<SectionTitle id="exp-title" eyebrow="always shipping">Activity</SectionTitle>

	<ol class="ledger">
		{
			jobs.map((j, i) => (
				<li class="row">
					<div class="meta">
						<span class="idx">{String(i + 1).padStart(2, '0')}</span>
						<span class="period">{j.period}</span>
					</div>
					<div class="detail">
						<h3 class="role">{j.role}</h3>
						<p class="org text-accent">{j.org}</p>
						<ul class="points">
							{j.points.map((p) => (
								<li class="text-muted fw-extralight">{p}</li>
							))}
						</ul>
					</div>
				</li>
			))
		}
	</ol>
</section>

<style>
	.ledger {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.row {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-4);
		padding-block: var(--space-8);
		border-top: 1px solid var(--color-border-line);
	}
	.row:last-child {
		border-bottom: 1px solid var(--color-border-line);
	}
	.meta {
		display: flex;
		align-items: baseline;
		gap: var(--space-4);
	}
	.idx {
		font-size: var(--fs-h3);
		line-height: 1;
		color: var(--color-primary);
		font-variant-numeric: tabular-nums;
	}
	.period {
		font-size: var(--fs-xs);
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: var(--color-text-muted);
	}
	.role {
		margin: 0;
		font-size: var(--fs-h2);
		font-weight: var(--fw-medium);
		line-height: 1.15;
	}
	.org {
		margin: var(--space-1) 0 var(--space-5);
		font-size: var(--fs-sm);
	}
	.points {
		margin: 0;
		padding: 0;
		list-style: none;
		display: grid;
		gap: var(--space-2);
		max-width: 48rem;
	}
	.points li {
		position: relative;
		padding-left: var(--space-5);
		font-size: var(--fs-sm);
	}
	.points li::before {
		content: '▹';
		position: absolute;
		left: 0;
		color: var(--color-accent);
	}

	@media (min-width: 768px) {
		.row {
			grid-template-columns: 15rem 1fr;
			gap: var(--space-10);
		}
		.meta {
			flex-direction: column;
			gap: var(--space-2);
		}
	}
</style>
