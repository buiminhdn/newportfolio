---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import SectionTitle from '../SectionTitle.astro';
import ProjectCard from '../ProjectCard.astro';
import Chip from '../Chip.astro';
import { featuredByKind, type ProjectKind } from '../../data/projects';

/** Featured section — one lead project + a grid below. Only featured items of `kind`. */
export interface Props {
	id: string;
	kind: ProjectKind;
	eyebrow?: string;
	title: string;
}
const { id, kind, eyebrow, title } = Astro.props;
const items = featuredByKind(kind);
const lead = items[0];
const rest = items.slice(1);

const projectImages = import.meta.glob<{ default: ImageMetadata }>(
	'../../assets/projects/*.{jpg,jpeg,png,webp,avif}',
	{ eager: true },
);
const imageFor = (slug: string): ImageMetadata | undefined => {
	const match = Object.entries(projectImages).find(([path]) =>
		path.split('/').pop()?.startsWith(`${slug}.`),
	);
	return match?.[1].default;
};
const leadImg = lead ? imageFor(lead.slug) : undefined;
const leadLive = lead?.links?.[0];
---

<section class="section container" id={id} aria-labelledby={`${id}-title`}>
	<SectionTitle id={`${id}-title`} eyebrow={eyebrow}>{title}</SectionTitle>

	{
		lead && (
			<article class="lead">
				<div class="lead-media">
					{leadImg ? (
						<Image src={leadImg} alt={`${lead.name} — preview`} width={1100} height={760} format="webp" loading="lazy" />
					) : (
						<img src="/placeholder.png" alt="" width={1100} height={760} loading="lazy" />
					)}
				</div>

				<div class="lead-body">
					<p class="mark">
						<span class="num">01</span>
						<span>Featured{lead.category ? ` · ${lead.category}` : ''}</span>
					</p>
					<h3 class="lead-title">{lead.name}</h3>
					<p class="lead-prop">{lead.tagline}</p>

					{lead.tech && lead.tech.length > 0 && (
						<ul class="stack">
							{lead.tech.map((t) => (
								<Chip as="li">{t}</Chip>
							))}
						</ul>
					)}

					{leadLive && (
						<div class="lead-actions">
							<a class="live link" href={leadLive.href} target="_blank" rel="noopener">
								{leadLive.label} ↗
							</a>
						</div>
					)}
				</div>
			</article>
		)
	}

	{
		rest.length > 0 && (
			<div class="gallery">
				{rest.map((p, i) => (
					<ProjectCard
						name={p.name}
						category={p.category}
						description={p.description}
						tech={p.tech}
						image={imageFor(p.slug)}
						index={i}
					/>
				))}
			</div>
		)
	}
</section>

<style>
	/* ── Lead (featured project lớn) ── */
	.lead {
		position: relative;
		display: grid;
		grid-template-columns: 1fr;
		overflow: hidden;
		border: 1px solid var(--color-border-line);
		background: var(--color-surface);
		margin-bottom: var(--space-8);
	}

	.lead-media {
		position: relative;
		aspect-ratio: 16 / 10;
		background: var(--color-secondary);
	}
	.lead-media :is(img) {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		max-width: none;
		object-fit: cover;
	}
	.lead-body {
		position: relative;
		z-index: 2;
		display: flex;
		flex-direction: column;
		gap: var(--space-5);
		padding: var(--space-8);
	}
	.mark {
		display: flex;
		align-items: center;
		gap: var(--space-3);
		margin: 0;
		font-family: var(--font);
		font-size: var(--fs-xs);
		text-transform: uppercase;
		letter-spacing: 0.16em;
		color: var(--color-text-muted);
	}
	.mark .num {
		font-family: var(--font);
		font-size: var(--fs-h3);
		line-height: 1;
		color: var(--color-primary);
	}
	.lead-title {
		margin: 0;
		font-family: var(--font);
		font-size: var(--fs-section);
		line-height: var(--lh-tight);
		letter-spacing: 0.01em;
	}
	.lead-prop {
		margin: 0;
		max-width: 42rem;
		font-size: var(--fs-lg);
		font-weight: var(--fw-light);
		color: var(--color-text-muted);
	}
	.stack {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2);
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.lead-actions {
		display: flex;
		align-items: center;
		gap: var(--space-6);
		margin-top: var(--space-2);
	}
	.live {
		font-family: var(--font);
		font-size: var(--fs-sm);
	}

	@media (min-width: 1024px) {
		.lead {
			grid-template-columns: 1.05fr 0.95fr;
			align-items: stretch;
		}
		.lead-media {
			aspect-ratio: auto;
			min-height: 27rem;
		}
		.lead-body {
			padding: var(--space-10);
			justify-content: center;
		}
	}

	/* ── Grid phụ ── */
	.gallery {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-6);
	}
	@media (min-width: 640px) {
		.gallery {
			grid-template-columns: repeat(2, 1fr);
		}
	}
	@media (min-width: 1024px) {
		.gallery {
			grid-template-columns: repeat(3, 1fr);
		}
	}
</style>
