---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

const roles = ['Android Engineer', 'Product Builder', 'UI Enthusiast'];

/**
 * Hero Stats — TODO: thay số liệu mẫu bằng METRIC THẬT (không bịa).
 * value = phần số, unit = ký hiệu (+ / K+ ...), label = nhãn mono.
 */
const stats = [
	{ value: '4', unit: '+', label: 'Years Experience' },
	{ value: '20', unit: '+', label: 'Projects' },
	{ value: '100', unit: 'K+', label: 'Users Impacted' },
	{ value: '10', unit: '+', label: 'Products Shipped' },
];

/**
 * Ảnh hero (LCP) — thả file vào src/assets/portrait.{jpg,png,webp}.
 * loading="eager" + fetchpriority="high". Chưa có ảnh → /placeholder.png.
 */
const portraitGlob = import.meta.glob<{ default: ImageMetadata }>(
	'../../assets/portrait.{jpg,jpeg,png,webp,avif}',
	{ eager: true },
);
const portrait = Object.values(portraitGlob)[0]?.default;
---

<section class="hero grid-bg" id="top" data-parallax-root>
	<div class="container hero-grid">
		<div class="hero-text reveal from-left">
			<p class="eyebrow">portfolio · bui quang minh</p>
			<h1 class="text-hero">Bui Quang Minh</h1>

			<ul class="roles" aria-label="Roles">
				{roles.map((r) => <li>{r}</li>)}
			</ul>

			<p class="headline">
				Building products that <span class="text-accent">people actually use.</span>
			</p>

			<div class="cta">
				<a href="#contact" class="btn-primary">CONTACT ME</a>
				<a href="#projects" class="link">VIEW WORK →</a>
			</div>
		</div>

		<div class="hero-media reveal from-right">
			<div class="parallax" data-parallax="20">
				<div class="media-frame tilt" data-tilt="10">
				{
					portrait ? (
						<Image
							class="portrait-img"
							src={portrait}
							alt="Bui Quang Minh"
							width={800}
							height={1000}
							format="webp"
							loading="eager"
							fetchpriority="high"
						/>
					) : (
						<img
							class="portrait-img"
							src="/placeholder.png"
							alt=""
							width={800}
							height={1000}
							loading="eager"
							fetchpriority="high"
						/>
					)
				}
					<span class="frame-tag">ANDROID · COMPOSE · PRODUCT</span>
				</div>
			</div>
		</div>
	</div>

	<!-- Hero Stats -->
	<div class="container">
		<dl class="stats reveal">
			{
				stats.map((s, i) => (
					<div class="metric" style={`--i:${i}`}>
						{/* TODO: số liệu thật */}
						<dd class="value">
							{s.value}
							<span class="unit">{s.unit}</span>
						</dd>
						<dt class="label">{s.label}</dt>
					</div>
				))
			}
		</dl>
	</div>
</section>

<style>
	.hero {
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: var(--space-20);
		min-height: 100svh;
		padding-block: var(--space-24) var(--space-16);
	}
	/* Grid nền ở hero sáng hơn một chút (chỉ riêng hero). */
	.hero.grid-bg::before {
		opacity: 0.62;
	}
	.hero-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-16);
		align-items: center;
	}
	.eyebrow {
		margin: 0 0 var(--space-5);
	}
	.text-hero {
		margin: 0;
	}
	.roles {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2) var(--space-4);
		list-style: none;
		padding: 0;
		margin: var(--space-4) 0 0;
		font-family: var(--font-mono);
		font-size: var(--fs-sm);
		color: var(--color-text-subtle);
	}
	.roles li:not(:last-child)::after {
		content: '·';
		margin-left: var(--space-4);
		color: var(--color-primary);
	}
	.headline {
		margin: var(--space-8) 0 0;
		max-width: 30rem;
		font-size: var(--fs-h2);
		font-weight: var(--fw-light);
		line-height: 1.25;
	}
	.cta {
		display: flex;
		align-items: center;
		gap: var(--space-6);
		margin-top: var(--space-10);
	}

	.media-frame {
		position: relative;
		border-radius: var(--radius-md);
		box-shadow: var(--glow-primary);
	}
	.portrait-img {
		width: 100%;
		height: auto;
		aspect-ratio: 4 / 5;
		object-fit: cover;
		border-radius: var(--radius-md);
		border: 1px solid var(--color-border-line);
	}
	.frame-tag {
		position: absolute;
		left: var(--space-4);
		bottom: var(--space-4);
		font-family: var(--font-mono);
		font-size: var(--fs-xs);
		letter-spacing: 0.12em;
		color: var(--color-text);
		background: rgba(8, 8, 11, 0.7);
		backdrop-filter: blur(6px);
		border: 1px solid var(--color-border-line);
		border-radius: var(--radius-full);
		padding: var(--space-1) var(--space-3);
	}

	.stats {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: var(--space-4);
		margin: 0;
	}
	.metric .value,
	.metric .label {
		margin: 0;
	}

	/* Tự sáng lần lượt theo --i (lặp). */
	.stats .metric {
		animation: stat-sweep 3.6s ease-in-out infinite;
		animation-delay: calc(var(--i) * 0.45s);
	}
	.stats .metric:hover {
		animation-play-state: paused; /* hover vẫn ưu tiên hiệu ứng hover */
	}
	@keyframes stat-sweep {
		0%, 60%, 100% {
			border-color: var(--color-border-line);
			box-shadow: none;
			transform: none;
		}
		25% {
			border-color: var(--color-primary);
			box-shadow: var(--glow-primary);
			transform: translateY(-2px);
		}
	}
	@media (prefers-reduced-motion: reduce) {
		.stats .metric { animation: none; }
	}

	@media (min-width: 768px) {
		.stats {
			grid-template-columns: repeat(4, 1fr);
			gap: var(--space-6);
		}
	}
	@media (min-width: 1024px) {
		.hero-grid {
			grid-template-columns: 1.25fr 1fr;
			gap: var(--space-20);
		}
	}
</style>
