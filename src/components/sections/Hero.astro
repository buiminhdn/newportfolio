---
import { Image } from "astro:assets";
import portrait from "../../assets/me.jpg";

const roles = ["Developer", "Designer", "Operator"];

const stats = [
  { value: "4", unit: "+", label: "Years Building" },
  { value: "20", unit: "+", label: "Projects Delivered" },
  { value: "4", unit: "", label: "Industries Worked With" },
  { value: "10", unit: "+", label: "Products Launched" },
];
---

<section class="hero" id="top">
  <div class="container hero-grid">
    <div class="hero-text">
      <p class="eyebrow">portfolio</p>
      <h1 class="text-hero">Bui Quang Minh</h1>

      <ul class="roles" aria-label="Roles">
        {roles.map((r) => <li>{r}</li>)}
      </ul>

      <p class="headline">
        Build products, improve processes<span class="text-accent">
          help businesses grow.</span
        >
      </p>

      <div class="cta">
        <a href="#contact" class="btn-primary">CONTACT ME</a>
        <a href="#work" class="link">VIEW WORK →</a>
      </div>
    </div>

    <div class="hero-media">
      <div class="media-frame">
        {
          portrait ? (
            <Image
              class="portrait-img"
              src={portrait}
              alt="Bui Quang Minh"
              width={800}
              height={1000}
              format="webp"
              loading="eager"
              fetchpriority="high"
            />
          ) : (
            <img
              class="portrait-img"
              src="/placeholder.png"
              alt=""
              width={800}
              height={1000}
              loading="eager"
              fetchpriority="high"
            />
          )
        }
        <span class="frame-tag">TECH · DESIGN · BUSINESS</span>
      </div>
    </div>
  </div>

  <!-- Hero Stats -->
  <div class="container">
    <dl class="stats">
      {
        stats.map((s) => (
          <div class="metric">
            <dd class="value">
              {s.value}
              <span class="unit">{s.unit}</span>
            </dd>
            <dt class="label">{s.label}</dt>
          </div>
        ))
      }
    </dl>
  </div>
</section>

<style>
  .hero {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--space-20);
    min-height: 100svh;
    padding-block: var(--space-24) var(--space-16);
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-16);
    align-items: center;
  }
  .eyebrow {
    margin: 0 0 var(--space-5);
  }
  .text-hero {
    margin: 0;
  }
  .roles {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-4);
    list-style: none;
    padding: 0;
    margin: var(--space-4) 0 0;
    font-family: var(--font);
    font-size: var(--fs-sm);
    color: var(--color-text-subtle);
  }
  .roles li:not(:last-child)::after {
    content: "·";
    margin-left: var(--space-4);
    color: var(--color-primary);
  }
  .headline {
    margin: var(--space-8) 0 0;
    max-width: 30rem;
    font-size: var(--fs-h2);
    font-weight: var(--fw-light);
    line-height: 1.25;
  }
  .cta {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    margin-top: var(--space-10);
  }

  .media-frame {
    position: relative;
    border-radius: var(--radius-md);
  }
  .portrait-img {
    width: 100%;
    height: auto;
    aspect-ratio: 1 / 1.05;
    object-fit: cover;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border-line);
  }
  .frame-tag {
    position: absolute;
    left: var(--space-4);
    bottom: var(--space-4);
    font-family: var(--font);
    font-size: var(--fs-xs);
    letter-spacing: 0.12em;
    color: var(--color-text);
    background: rgba(8, 8, 11, 0.7);
    border: 1px solid var(--color-border-line);
    border-radius: var(--radius-full);
    padding: var(--space-1) var(--space-3);
  }

  .stats {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
    margin: 0;
  }
  .metric .value,
  .metric .label {
    margin: 0;
  }

  @media (min-width: 768px) {
    .stats {
      grid-template-columns: repeat(4, 1fr);
      gap: var(--space-6);
    }
  }
  @media (min-width: 1024px) {
    .hero-grid {
      grid-template-columns: 1.25fr 1fr;
      gap: var(--space-20);
    }
  }
</style>
