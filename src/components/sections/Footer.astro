---
const year = new Date().getFullYear();
---

<footer class="footer">
	<div class="container footer-inner">
		<p class="display brand">Bùi Quang Minh</p>
		<p class="text-muted">© {year} — Android & Web Developer · UI/UX Designer</p>
	</div>
	<a href="#top" class="btn-float">↑ Top</a>
</footer>

<style>
	.footer {
		border-top: 1px solid var(--color-border-line);
		margin-top: var(--space-32);
		padding-block: var(--space-16);
	}
	.footer-inner {
		display: flex;
		flex-direction: column;
		gap: var(--space-2);
	}
	.brand {
		font-size: var(--fs-h3);
		margin: 0;
	}
	.footer-inner p:last-child {
		margin: 0;
		font-size: var(--fs-sm);
	}
</style>
