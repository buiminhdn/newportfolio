---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Chip from './Chip.astro';

/**
 * Gallery card — ảnh trên, nội dung dưới. Có 3D tilt (data-tilt) + brutal hover.
 * Toàn bộ card là link sang trang chi tiết /projects/<slug>.
 * `image` = ImageMetadata (astro:assets, tự WebP). Chưa có → /placeholder.png.
 */
export interface Props {
	slug: string;
	name: string;
	category?: string;
	description: string;
	tech?: string[];
	image?: ImageMetadata;
	index?: number;
}
const { slug, name, category, description, tech = [], image, index = 0 } = Astro.props;
const href = `/projects/${slug}`;
---

<article class="pcard brutal tilt reveal" data-tilt="5" style={`--i:${index}`}>
	<a class="pcard-link" href={href} aria-label={`${name} — view case study`}>
		<div class="thumb">
			{category && <span class="cat eyebrow">{category}</span>}
			{
				image ? (
					<Image src={image} alt={`${name} — preview`} width={600} height={400} format="webp" loading="lazy" />
				) : (
					<img src="/placeholder.png" alt="" width={600} height={400} loading="lazy" />
				)
			}
		</div>

		<div class="body">
			<h3 class="text-h3">{name}</h3>
			<p class="desc fw-extralight text-muted">{description}</p>

			{
				tech.length > 0 && (
					<ul class="stack">
						{tech.map((t) => (
							<Chip as="li">{t}</Chip>
						))}
					</ul>
				)
			}

			<span class="more-link text-accent">View case study →</span>
		</div>
	</a>
</article>

<style>
	.pcard {
		display: flex;
		flex-direction: column;
		overflow: hidden;
		border-width: 1px;
		border-color: var(--color-border-line);
		box-shadow: none;
	}
	.pcard:hover {
		transform: perspective(800px) rotateX(var(--rx, 0deg)) rotateY(var(--ry, 0deg));
		border-color: var(--color-primary);
		box-shadow: var(--glow-primary);
	}
	.pcard-link {
		display: flex;
		flex-direction: column;
		height: 100%;
		color: inherit;
		text-decoration: none;
	}
	.thumb {
		position: relative;
		aspect-ratio: 3 / 2;
		background: var(--color-surface);
	}
	.thumb img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}
	.cat {
		position: absolute;
		top: var(--space-3);
		left: var(--space-3);
		background: rgba(8, 8, 11, 0.72);
		backdrop-filter: blur(6px);
		border: 1px solid var(--color-border-line);
		border-radius: var(--radius-full);
		padding: var(--space-1) var(--space-3);
	}
	.cat::before { content: ''; }
	.body {
		display: flex;
		flex-direction: column;
		gap: var(--space-3);
		padding: var(--space-6);
		flex: 1;
	}
	.body h3 {
		margin: 0;
	}
	.desc {
		margin: 0;
		font-size: var(--fs-sm);
	}
	.stack {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2);
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.more-link {
		margin-top: auto;
		padding-top: var(--space-2);
		font-family: var(--font-mono);
		font-size: var(--fs-sm);
		transition: transform var(--dur-fast);
	}
	.pcard:hover .more-link {
		transform: translateX(4px);
	}
</style>
