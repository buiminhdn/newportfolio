---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Chip from './Chip.astro';

/**
 * Gallery card — image on top, content below.
 * `image` = ImageMetadata (astro:assets, auto WebP); none → /placeholder.png.
 */
export interface Props {
	name: string;
	category?: string;
	description: string;
	tech?: string[];
	image?: ImageMetadata;
	index?: number;
}
const { name, category, description, tech = [], image } = Astro.props;
---

<article class="pcard">
	<div class="thumb">
		{category && <span class="cat eyebrow">{category}</span>}
		{
			image ? (
				<Image src={image} alt={`${name} — preview`} width={600} height={400} format="webp" loading="lazy" />
			) : (
				<img src="/placeholder.png" alt="" width={600} height={400} loading="lazy" />
			)
		}
	</div>

	<div class="body">
		<h3 class="text-h3">{name}</h3>
		<p class="desc fw-extralight text-muted">{description}</p>

		{
			tech.length > 0 && (
				<ul class="stack">
					{tech.map((t) => (
						<Chip as="li">{t}</Chip>
					))}
				</ul>
			)
		}
	</div>
</article>

<style>
	.pcard {
		display: flex;
		flex-direction: column;
		height: 100%;
		overflow: hidden;
		border: 1px solid var(--color-border-line);
		background: var(--color-secondary);
	}
	.thumb {
		position: relative;
		aspect-ratio: 3 / 2;
		background: var(--color-surface);
	}
	.thumb img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}
	.cat {
		position: absolute;
		top: var(--space-3);
		left: var(--space-3);
		background: rgba(8, 8, 11, 0.72);
		border: 1px solid var(--color-border-line);
		border-radius: var(--radius-full);
		padding: var(--space-1) var(--space-3);
	}
	.body {
		display: flex;
		flex-direction: column;
		gap: var(--space-3);
		padding: var(--space-6);
		flex: 1;
	}
	.body h3 {
		margin: 0;
	}
	.desc {
		margin: 0;
		font-size: var(--fs-sm);
	}
	.stack {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2);
		list-style: none;
		margin: 0;
		padding: 0;
	}
</style>
