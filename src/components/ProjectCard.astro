---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Chip from './Chip.astro';

/**
 * Gallery card — ảnh trên, nội dung dưới. Có 3D tilt (data-tilt) + brutal hover.
 * `image` = ImageMetadata (astro:assets, tự WebP). Chưa có → /placeholder.png.
 * `metric` = slot impact (TODO số liệu thật, optional).
 */
export interface Props {
	name: string;
	category?: string;
	description: string;
	tech?: string[];
	metric?: string;
	links?: { label: string; href: string }[];
	image?: ImageMetadata;
	index?: number;
}
const { name, category, description, tech = [], metric, links = [], image, index = 0 } = Astro.props;
---

<article class="pcard brutal tilt reveal" data-tilt="5" style={`--i:${index}`}>
	<div class="thumb">
		{category && <span class="cat eyebrow">{category}</span>}
		{
			image ? (
				<Image src={image} alt={`${name} — preview`} width={600} height={400} format="webp" loading="lazy" />
			) : (
				<img src="/placeholder.png" alt="" width={600} height={400} loading="lazy" />
			)
		}
	</div>

	<div class="body">
		<h3 class="text-h3">{name}</h3>
		<p class="desc fw-extralight text-muted">{description}</p>

		{
			metric && (
				<p class="metric-inline">
					{/* TODO: số liệu thật */}
					<span class="text-accent">{metric}</span>
				</p>
			)
		}

		{
			tech.length > 0 && (
				<ul class="stack">
					{tech.map((t) => (
						<Chip as="li">{t}</Chip>
					))}
				</ul>
			)
		}

		{
			links.length > 0 && (
				<div class="links">
					{links.map((l) => (
						<a href={l.href} class="link" target="_blank" rel="noopener">
							{l.label} ↗
						</a>
					))}
				</div>
			)
		}
	</div>
</article>

<style>
	.pcard {
		display: flex;
		flex-direction: column;
		overflow: hidden;
		border-width: 1px;
		border-color: var(--color-border-line);
		box-shadow: none;
	}
	.pcard:hover {
		transform: perspective(800px) rotateX(var(--rx, 0deg)) rotateY(var(--ry, 0deg));
		border-color: var(--color-primary);
		box-shadow: var(--glow-primary);
	}
	.thumb {
		position: relative;
		aspect-ratio: 3 / 2;
		background: var(--color-surface);
	}
	.thumb img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}
	.cat {
		position: absolute;
		top: var(--space-3);
		left: var(--space-3);
		background: rgba(8, 8, 11, 0.72);
		backdrop-filter: blur(6px);
		border: 1px solid var(--color-border-line);
		border-radius: var(--radius-full);
		padding: var(--space-1) var(--space-3);
	}
	.cat::before { content: ''; }
	.body {
		display: flex;
		flex-direction: column;
		gap: var(--space-3);
		padding: var(--space-6);
	}
	.body h3 {
		margin: 0;
	}
	.desc {
		margin: 0;
		font-size: var(--fs-sm);
	}
	.metric-inline {
		margin: 0;
		font-family: var(--font-mono);
		font-size: var(--fs-sm);
	}
	.stack {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2);
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.links {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-4);
		margin-top: auto;
		padding-top: var(--space-2);
	}
</style>
