---
/** Tiêu đề section in hoa kiểu display. */
export interface Props {
	id?: string;
	eyebrow?: string;
}
const { id, eyebrow } = Astro.props;
---

<header class="section-title reveal" id={id}>
	{eyebrow && <p class="text-primary fw-medium">{eyebrow}</p>}
	<h2 class="text-section">
		<slot />
	</h2>
</header>

<style>
	.section-title {
		margin-bottom: var(--space-16);
	}
	.section-title p {
		margin: 0 0 var(--space-2);
		font-size: var(--fs-sm);
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}
	.section-title h2 {
		margin: 0;
	}
</style>
