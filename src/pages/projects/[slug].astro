---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/sections/Nav.astro';
import Footer from '../../components/sections/Footer.astro';
import Chip from '../../components/Chip.astro';
import { projects, type Project } from '../../data/projects';

/**
 * Trang chi tiết 1 project — /projects/<slug>.
 * Tự sinh static từ src/data/projects.ts. Chỉ render phần nào có dữ liệu.
 * Ảnh hero: src/assets/projects/<slug>.* — chưa có → /placeholder.png.
 */
export function getStaticPaths() {
	return projects.map((project) => ({
		params: { slug: project.slug },
		props: { project },
	}));
}

interface Props {
	project: Project;
}
const { project } = Astro.props;

const projectImages = import.meta.glob<{ default: ImageMetadata }>(
	'../../assets/projects/*.{jpg,jpeg,png,webp,avif}',
	{ eager: true },
);
const match = Object.entries(projectImages).find(([path]) =>
	path.split('/').pop()?.startsWith(`${project.slug}.`),
);
const shot = match?.[1].default;

const kindLabel = project.kind === 'design' ? 'Design (Canva)' : 'Web / App';
const title = `${project.name} — ${kindLabel} · Bui Quang Minh`;
---

<Layout title={title} description={project.tagline}>
	<Nav />
	<main>
		<article class="section container grid-bg" data-parallax-root>
			<a href="/#work" class="back link">← Back to work</a>

			<header class="head reveal">
				<p class="text-primary fw-medium kind">{kindLabel}{project.category ? ` · ${project.category}` : ''}</p>
				<h1 class="text-section">{project.name}</h1>
				<p class="tagline lead text-muted">{project.tagline}</p>

				{
					project.tech && project.tech.length > 0 && (
						<ul class="stack">
							{project.tech.map((t) => (
								<Chip as="li">{t}</Chip>
							))}
						</ul>
					)
				}

				{
					project.links && project.links.length > 0 && (
						<div class="links">
							{project.links.map((l) => (
								<a href={l.href} class="link" target="_blank" rel="noopener">
									{l.label} ↗
								</a>
							))}
						</div>
					)
				}
			</header>

			<div class="parallax shot-wrap" data-parallax="10">
				<div class="shot brutal tilt" data-tilt="5">
					{
						shot ? (
							<Image src={shot} alt={`${project.name} — screenshot`} width={1200} height={800} format="webp" loading="eager" />
						) : (
							<img src="/placeholder.png" alt="" width={1200} height={800} loading="eager" />
						)
					}
				</div>
			</div>

			<div class="case">
				{
					project.problem && (
						<section class="block reveal">
							<p class="eyebrow">problem</p>
							<p class="text-muted">{project.problem}</p>
						</section>
					)
				}

				{
					project.solution && (
						<section class="block reveal">
							<p class="eyebrow">solution</p>
							<p class="text-muted">{project.solution}</p>
						</section>
					)
				}

				{
					project.challenges && project.challenges.length > 0 && (
						<section class="block reveal">
							<p class="eyebrow">challenges</p>
							<ul class="list">
								{project.challenges.map((c) => (
									<li>{c}</li>
								))}
							</ul>
						</section>
					)
				}

				{
					project.decisions && project.decisions.length > 0 && (
						<section class="block reveal">
							<p class="eyebrow">key decisions</p>
							<ul class="decisions">
								{project.decisions.map((x) => (
									<li>
										<span class="d">{x.d}</span>
										<span class="why text-muted">{x.why}</span>
									</li>
								))}
							</ul>
						</section>
					)
				}
			</div>

			{
				project.results && project.results.length > 0 && (
					<div class="results reveal">
						<p class="eyebrow">results</p>
						{/* TODO: số liệu thật */}
						<dl class="results-grid">
							{project.results.map((r) => (
								<div class="metric">
									<dd class="value">
										{r.value}
										{r.unit && <span class="unit">{r.unit}</span>}
									</dd>
									<dt class="label">{r.label}</dt>
								</div>
							))}
						</dl>
					</div>
				)
			}

			<a href="/#work" class="back back-bottom link">← Back to work</a>
		</article>
	</main>
	<Footer />
</Layout>

<style>
	.back {
		display: inline-block;
		font-family: var(--font-mono);
		font-size: var(--fs-sm);
		margin-bottom: var(--space-12);
	}
	.back-bottom {
		margin-top: var(--space-20);
		margin-bottom: 0;
	}
	.head {
		max-width: 52rem;
		margin-bottom: var(--space-16);
	}
	.kind {
		margin: 0 0 var(--space-3);
		font-size: var(--fs-sm);
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}
	.head h1 {
		margin: 0 0 var(--space-6);
	}
	.tagline {
		margin: 0 0 var(--space-6);
	}
	.stack {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2);
		list-style: none;
		margin: 0 0 var(--space-6);
		padding: 0;
	}
	.links {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-4);
	}

	.shot-wrap {
		margin-bottom: var(--space-20);
	}
	.shot :is(img) {
		width: 100%;
		height: auto;
		display: block;
		border-radius: calc(var(--radius-md) - 2px);
	}

	.case {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-16);
	}
	.block .eyebrow {
		display: block;
		margin-bottom: var(--space-4);
	}
	.block p {
		margin: 0;
		max-width: 46rem;
	}
	.list,
	.decisions {
		margin: 0;
		padding: 0;
		list-style: none;
		display: grid;
		gap: var(--space-4);
		max-width: 46rem;
	}
	.list li {
		position: relative;
		padding-left: var(--space-6);
		color: var(--color-text-muted);
	}
	.list li::before {
		content: '';
		position: absolute;
		left: 0;
		top: 0.6em;
		width: 0.5rem;
		height: 0.5rem;
		border-radius: var(--radius-full);
		background: var(--color-accent);
	}
	.decisions li {
		display: grid;
		gap: var(--space-1);
		padding-left: var(--space-6);
		border-left: 2px solid var(--color-primary);
	}
	.decisions .d {
		font-weight: var(--fw-medium);
	}
	.decisions .why {
		font-size: var(--fs-sm);
	}

	.results {
		margin-top: var(--space-20);
	}
	.results > .eyebrow {
		display: block;
		margin-bottom: var(--space-6);
	}
	.results-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: var(--space-4);
		margin: 0;
	}
	.results-grid .value,
	.results-grid .label {
		margin: 0;
	}

	@media (min-width: 768px) {
		.case {
			grid-template-columns: 1fr 1fr;
			gap: var(--space-16) var(--space-20);
		}
		.results-grid {
			grid-template-columns: repeat(4, 1fr);
			gap: var(--space-6);
		}
	}
</style>
