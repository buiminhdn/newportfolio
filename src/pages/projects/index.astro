---
import type { ImageMetadata } from 'astro';
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/sections/Nav.astro';
import Footer from '../../components/sections/Footer.astro';
import SectionTitle from '../../components/SectionTitle.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { projects, type ProjectKind } from '../../data/projects';

/**
 * Trang liệt kê TẤT CẢ dự án — /projects.
 * Khác trang home: home chỉ show featured, trang này show toàn bộ, tách theo kind.
 */
const projectImages = import.meta.glob<{ default: ImageMetadata }>(
	'../../assets/projects/*.{jpg,jpeg,png,webp,avif}',
	{ eager: true },
);
const imageFor = (slug: string): ImageMetadata | undefined => {
	const match = Object.entries(projectImages).find(([path]) =>
		path.split('/').pop()?.startsWith(`${slug}.`),
	);
	return match?.[1].default;
};

const groups: { kind: ProjectKind; eyebrow: string; title: string }[] = [
	{ kind: 'web-app', eyebrow: 'all work · web & app', title: 'Web & App' },
	{ kind: 'design', eyebrow: 'all work · design', title: 'Design (Canva)' },
];
---

<Layout title="All Projects — Bui Quang Minh" description="All projects by Bui Quang Minh — web, app and design work.">
	<Nav />
	<main>
		<section class="section container">
			<a href="/#work" class="back link">← Back to home</a>

			{
				groups.map(({ kind, eyebrow, title }) => {
					const items = projects.filter((p) => p.kind === kind);
					return (
						items.length > 0 && (
							<div class="group" id={kind}>
								<SectionTitle eyebrow={eyebrow}>{title}</SectionTitle>
								<div class="gallery">
									{items.map((p, i) => (
										<ProjectCard
											slug={p.slug}
											name={p.name}
											category={p.category}
											description={p.description}
											tech={p.tech}
											image={imageFor(p.slug)}
											index={i}
										/>
									))}
								</div>
							</div>
						)
					);
				})
			}
		</section>
	</main>
	<Footer />
</Layout>

<style>
	.back {
		display: inline-block;
		font-family: var(--font-mono);
		font-size: var(--fs-sm);
		margin-bottom: var(--space-12);
	}
	.group + .group {
		margin-top: var(--space-32);
	}
	.gallery {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-8);
	}
	@media (min-width: 640px) {
		.gallery {
			grid-template-columns: repeat(2, 1fr);
		}
	}
	@media (min-width: 1024px) {
		.gallery {
			grid-template-columns: repeat(3, 1fr);
		}
	}
</style>
